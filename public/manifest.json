{
  "manifest_version": 3,
  "name": "Bob Hates Your Diagrams",
  "version": "1.3.0",
  "description": "Боб ненавидит твои диаграммы, но всё равно переводит. Конвертирует бэкап unidraw.io в Mermaid.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://unidraw.io/*"],
  "content_scripts": [
    {
      "matches": ["https://unidraw.io/app/board/*"],
      "js": ["content_script.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://unidraw.io/app/board/*"],
      "js": ["content_script_bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
